rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "wiillsantos16@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function getJudgementVal(data, key) {
      return ('judgement' in data && key in data.judgement) ? data.judgement[key] : 0;
    }

    function isValidConfession() {
      let data = request.resource.data;
      return data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             data.category is string && data.category in ['Relacionamentos', 'Segredos', 'Família', 'Sexo', 'Vida', 'Arrependimentos'] &&
             (!('age' in data) || (data.age is number && data.age >= 13 && data.age <= 120)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 50)) &&
             (!('background' in data) || (data.background is string && data.background.size() <= 200)) &&
             (!('isHidden' in data) || data.isHidden is bool) &&
             data.likes is number &&
             data.commentCount is number &&
             (!('judgement' in data) || (data.judgement is map && 
               (!('right' in data.judgement) || data.judgement.right is number) && 
               (!('wrong' in data.judgement) || data.judgement.wrong is number))) &&
             data.createdAt is timestamp &&
             data.authorId is string && data.authorId == request.auth.uid;
    }

    function isValidComment() {
      let data = request.resource.data;
      return data.confessionId is string &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             (!('likes' in data) || data.likes is number) &&
             (!('isHidden' in data) || data.isHidden is bool) &&
             data.createdAt is timestamp &&
             data.authorId is string && data.authorId == request.auth.uid;
    }

    function isValidNickname(nickname) {
      return nickname is string && nickname.size() >= 3 && nickname.size() <= 20 &&
             !nickname.lower().matches('.*(porno|sexo|puta|caralho|buceta|pau|cu|foda|conselheiro|counselor).*');
    }

    function isValidProfile(data) {
      return (!('nickname' in data) || isValidNickname(data.nickname)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 50)) &&
             (!('maritalStatus' in data) || (data.maritalStatus is string && data.maritalStatus.size() <= 50)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 2000)) &&
             (!('role' in data) || data.role in ['user', 'admin']) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('isShadowBanned' in data) || data.isShadowBanned is bool) &&
             (!('lastActive' in data) || data.lastActive is timestamp) &&
             (!('isAnonymous' in data) || data.isAnonymous is bool) &&
             (!('karma' in data) || data.karma is number);
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidNickname(request.resource.data.nickname) &&
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin()) &&
                    (!('isShadowBanned' in request.resource.data) || request.resource.data.isShadowBanned == false || isAdmin()) &&
                    (!('karma' in request.resource.data) || request.resource.data.karma == 0 || isAdmin());
      allow update: if (isOwner(userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nickname', 'lastActive', 'gender', 'maritalStatus', 'bio', 'avatar', 'role', 'isVerified', 'isShadowBanned', 'karma']) &&
                    isValidProfile(request.resource.data) &&
                    (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isVerified', 'isShadowBanned', 'karma']) ||
                      isAdmin()
                    )) || 
                    // Allow karma updates for others (likes/best comment)
                    (isAuthenticated() && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['karma']) &&
                     math.abs(request.resource.data.karma - resource.data.karma) <= 10) ||
                    isAdmin();
      allow delete: if isOwner(userId) || isAdmin();

      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /chats/{chatId} {
      allow read, write: if isAuthenticated();

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /confessions/{confessionId} {
      // Anyone can read confessions
      allow read: if true;
      
      // Authenticated users can create confessions
      allow create: if isAuthenticated() && 
                    isValidConfession() && 
                    request.resource.data.likes == 0 && 
                    request.resource.data.commentCount == 0;
                    
      // Updates are only allowed for likes, commentCount, and judgement
      allow update: if isAuthenticated() &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentCount', 'judgement']) &&
                    // Likes can only change by 1 or -1 AND must be accompanied by a like document change
                    (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes']) ||
                      (
                        request.resource.data.likes == resource.data.likes + 1 &&
                        !exists(/databases/$(database)/documents/confessions/$(confessionId)/likes/$(request.auth.uid)) &&
                        getAfter(/databases/$(database)/documents/confessions/$(confessionId)/likes/$(request.auth.uid)) != null
                      ) || 
                      (
                        request.resource.data.likes == resource.data.likes - 1 &&
                        exists(/databases/$(database)/documents/confessions/$(confessionId)/likes/$(request.auth.uid)) &&
                        getAfter(/databases/$(database)/documents/confessions/$(confessionId)/likes/$(request.auth.uid)) == null
                      )
                    ) &&
                    // Comment count can only change by 1 when a comment is created/deleted
                    (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['commentCount']) ||
                      (request.resource.data.commentCount == resource.data.commentCount + 1) ||
                      (request.resource.data.commentCount == resource.data.commentCount - 1)
                    ) &&
                    // Judgement can only change by 1 or -1 AND must be accompanied by a judgement document change
                    (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['judgement']) ||
                      (
                        (
                          getJudgementVal(request.resource.data, 'right') == getJudgementVal(resource.data, 'right') + 1 &&
                          !exists(/databases/$(database)/documents/confessions/$(confessionId)/judgements/$(request.auth.uid)) &&
                          getAfter(/databases/$(database)/documents/confessions/$(confessionId)/judgements/$(request.auth.uid)).data.vote == 'right'
                        ) ||
                        (
                          getJudgementVal(request.resource.data, 'right') == getJudgementVal(resource.data, 'right') - 1 &&
                          exists(/databases/$(database)/documents/confessions/$(confessionId)/judgements/$(request.auth.uid)) &&
                          resource.data.judgement.right > 0 &&
                          getAfter(/databases/$(database)/documents/confessions/$(confessionId)/judgements/$(request.auth.uid)) == null
                        ) ||
                        (getJudgementVal(request.resource.data, 'right') == getJudgementVal(resource.data, 'right'))
                      ) &&
                      (
                        (
                          getJudgementVal(request.resource.data, 'wrong') == getJudgementVal(resource.data, 'wrong') + 1 &&
                          !exists(/databases/$(database)/documents/confessions/$(confessionId)/judgements/$(request.auth.uid)) &&
                          getAfter(/databases/$(database)/documents/confessions/$(confessionId)/judgements/$(request.auth.uid)).data.vote == 'wrong'
                        ) ||
                        (
                          getJudgementVal(request.resource.data, 'wrong') == getJudgementVal(resource.data, 'wrong') - 1 &&
                          exists(/databases/$(database)/documents/confessions/$(confessionId)/judgements/$(request.auth.uid)) &&
                          resource.data.judgement.wrong > 0 &&
                          getAfter(/databases/$(database)/documents/confessions/$(confessionId)/judgements/$(request.auth.uid)) == null
                        ) ||
                        (getJudgementVal(request.resource.data, 'wrong') == getJudgementVal(resource.data, 'wrong'))
                      )
                    );
                    
      allow delete: if isOwner(resource.data.authorId) || isAdmin();

      match /likes/{userId} {
        allow read: if true;
        allow create: if isOwner(userId) && request.resource.data.createdAt is timestamp;
        allow delete: if isOwner(userId);
      }

      match /judgements/{userId} {
        allow read: if true;
        allow create, update: if isOwner(userId) && request.resource.data.vote in ['right', 'wrong'] && request.resource.data.createdAt is timestamp;
      }
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment() && (!('likes' in request.resource.data) || request.resource.data.likes == 0);
      allow update: if isAuthenticated() &&
                    (
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
                      (request.resource.data.likes == resource.data.likes + 1 || request.resource.data.likes == resource.data.likes - 1)) ||
                      // Allow author of confession to mark as best
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isBest']) &&
                       get(/databases/$(database)/documents/confessions/$(resource.data.confessionId)).data.authorId == request.auth.uid)
                    );
      allow delete: if isOwner(resource.data.authorId) || isAdmin();

      match /likes/{userId} {
        allow read: if true;
        allow create: if isOwner(userId) && request.resource.data.createdAt is timestamp;
        allow delete: if isOwner(userId);
      }
    }

    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuthenticated() &&
                    request.resource.data.confessionId is string &&
                    (!('commentId' in request.resource.data) || request.resource.data.commentId is string) &&
                    (!('type' in request.resource.data) || request.resource.data.type in ['confession', 'comment']) &&
                    request.resource.data.reportedBy == request.auth.uid &&
                    request.resource.data.reason is string &&
                    request.resource.data.reason.size() > 0 &&
                    request.resource.data.reason.size() <= 500 &&
                    request.resource.data.status == 'pending' &&
                    request.resource.data.createdAt is timestamp;
    }
  }
}
