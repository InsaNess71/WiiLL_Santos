rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidConfession() {
      let data = request.resource.data;
      return data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             data.category is string && data.category in ['Relacionamentos', 'Segredos', 'Família', 'Sexo', 'Vida', 'Arrependimentos'] &&
             (!('age' in data) || (data.age is number && data.age >= 13 && data.age <= 120)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 50)) &&
             data.likes is number &&
             data.commentCount is number &&
             data.createdAt is timestamp &&
             data.authorId is string && data.authorId == request.auth.uid;
    }

    function isValidComment() {
      let data = request.resource.data;
      return data.confessionId is string &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdAt is timestamp &&
             data.authorId is string && data.authorId == request.auth.uid;
    }

    function isValidNickname(nickname) {
      return nickname is string && nickname.size() >= 3 && nickname.size() <= 20 &&
             !nickname.lower().matches('.*(porno|sexo|puta|caralho|buceta|pau|cu|foda).*');
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidNickname(request.resource.data.nickname);
      allow update: if isOwner(userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nickname', 'lastActive']) &&
                    (!('nickname' in request.resource.data.diff(resource.data).affectedKeys()) || isValidNickname(request.resource.data.nickname));
    }

    match /chats/{chatId} {
      allow get: if isAuthenticated() && (resource == null || request.auth.uid in resource.data.participants);
      allow list: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
                    request.auth.uid in request.resource.data.participants &&
                    request.resource.data.participants is list &&
                    request.resource.data.participants.size() == 2 &&
                    request.resource.data.durationMode in ['1h', '24h'] &&
                    request.resource.data.expiresAt is timestamp;
      allow update: if isAuthenticated() && 
                    request.auth.uid in resource.data.participants &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'lastMessage', 'unreadCount', 'durationMode', 'expiresAt']) &&
                    request.resource.data.participants == resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() &&
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() > 0 &&
                      request.resource.data.text.size() <= 1000 &&
                      request.resource.data.senderId == request.auth.uid;
      }
    }

    match /confessions/{confessionId} {
      // Anyone can read confessions
      allow read: if true;
      
      // Authenticated users can create confessions
      allow create: if isAuthenticated() && 
                    isValidConfession() && 
                    request.resource.data.likes == 0 && 
                    request.resource.data.commentCount == 0;
                    
      // Updates are only allowed for likes and commentCount
      allow update: if isAuthenticated() &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentCount']) &&
                    // Likes can only change by 1 or -1
                    (
                      (request.resource.data.likes == resource.data.likes + 1 || request.resource.data.likes == resource.data.likes - 1) ||
                      (request.resource.data.likes == resource.data.likes)
                    ) &&
                    // Comment count can only increase by 1
                    (
                      request.resource.data.commentCount == resource.data.commentCount + 1 ||
                      request.resource.data.commentCount == resource.data.commentCount
                    );
                    
      allow delete: if isOwner(resource.data.authorId);

      match /likes/{userId} {
        allow read: if true;
        allow create: if isOwner(userId) && request.resource.data.createdAt is timestamp;
        allow delete: if isOwner(userId);
      }
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment();
      allow delete: if isOwner(resource.data.authorId);
    }
  }
}
